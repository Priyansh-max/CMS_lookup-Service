# CMS Credentials (you may not need all of these)
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_REDIRECT_URI=
CLIO_AUTH_URL=https://app.clio.com/oauth/authorize
CLIO_TOKEN_URL=https://app.clio.com/oauth/token
CLIO_SCOPES=matters:read,contacts:read
CLIO_API_BASE_URL=https://app.clio.com/api/v4

# Optional default sync requests used by startup/manual sync
FILEVINE_FIRM_ID=firm-filevine
FILEVINE_SAMPLE_PATH=

# Primary application database (PostgreSQL only)
DATABASE_URL=

# Dedicated automated test database (do not point this at production)
TEST_DATABASE_URL=


# Scheduler
#true or false depending on if you want to enable the scheduler
SCHEDULER_ENABLED=false
#interval in seconds for the scheduler
SYNC_INTERVAL_SECONDS=300

